{#
/**
 * @file
 * CTA atom – link styled as a button.
 *
 * Available config:
 * - title: Button/link text.
 * - url: Internal or external URL.
 * - variant: primary | outline.
 * - target: _self | _blank.
 * - color: Optional custom background/border color.
 * - text_color: Optional custom text color.
 */
#}
{% set variant = variant|default('primary') %}
{% set target = target|default('_self') %}
{% set base_class = 'cta' %}
{% set modifier_class = base_class ~ '--' ~ variant %}

{% set inline_styles = [] %}
{% if color %}
  {% if variant == 'primary' %}
    {% set inline_styles = inline_styles|merge(['background-color: ' ~ color, 'border-color: ' ~ color]) %}
  {% else %}
    {% set inline_styles = inline_styles|merge(['border-color: ' ~ color, 'color: ' ~ color]) %}
  {% endif %}
{% endif %}
{% if text_color and variant == 'primary' %}
  {% set inline_styles = inline_styles|merge(['color: ' ~ text_color]) %}
{% endif %}

{% set style_attr = inline_styles|length > 0 ? inline_styles|join('; ') : '' %}

{# Create fresh attributes for this component to avoid conflicts when nested #}
{% set cta_attributes = create_attribute() %}
{% set cta_attributes = cta_attributes.addClass(base_class, modifier_class) %}

<a
  {{ cta_attributes }}
  href="{{ url }}"
  {% if target == '_blank' %}
    target="_blank"
    rel="noopener noreferrer"
  {% endif %}
  {% if style_attr %}
    style="{{ style_attr }}"
  {% endif %}
>
  <span class="cta__label">{{ title }}</span>
</a>
