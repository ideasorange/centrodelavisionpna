{#
 * Social Icon atom – icon-only link for social networks.
 #}
{% set base_class = 'social-icon' %}
{% set icon_attributes = attributes ? attributes.addClass(base_class) : create_attribute().addClass(base_class) %}
{% set target = target|default('_blank') %}

<a
  {{ icon_attributes }}
  href="{{ url }}"
  {% if target == '_blank' %}
    target="_blank"
    rel="noopener noreferrer"
  {% endif %}
  {% if label %}
    aria-label="{{ label }}"
  {% endif %}
>
  <span class="{{ base_class }}__icon" aria-hidden="true">
    <ion-icon name="{{ icon }}"></ion-icon>
  </span>
</a>
