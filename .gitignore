# Logs and temp
*.log
*.tmp

# Ignore SO files
.DS_Store
.idea
.idea/
.vscode
.vscode/
.cursor/
*.code-workspace
.ddev
.ddev/
db_local_ddev.sql

# Ignore contributed code.
vendor
/vendor/
vendor/
vendor/*
web/core
web/modules/contrib
web/profiles/contrib
web/themes/contrib
web/sites/default/files


# Ignore dev files
node_modules
web/themes/**/build
web/themes/**/yarn-error.log


# Ignore scaffolded files.
web/.csslintrc
web/.eslintignore
web/.eslintrc.json
web/.ht.router.php
web/.htaccess
web/autoload.php
web/example.gitignore
web/index.php
web/INSTALL.txt
web/README.md
web/robots.txt
web/update.php
web/web.config
/.editorconfig
/.gitattributes


# Ignore logs.
logs
!logs/.gitkeep


# Ignore directories generated by Composer
/.drush-lock-update
/drush/Commands/contrib/
/drush/sites/lagoon.site.yml
/vendor/


# Ignore directories generated by yarn
/node_modules/
/test/
/yarn.lock
/package.json


# Ignore Drupal's file directory
/web/sites/*/files/
web/sites/*/private/


# Ingore files that are only for the current local environment
web/sites/*/settings.local.php
web/sites/*/services.local.yml
web/sites/*/settings.ddev.php
web/sites/*/services.ddev.yml

# Drupal files
web/sites/*/files/

web/sites/*/settings.php
web/sites/*/settings.local.php
web/sites/*/services.yml
web/sites/*/services.local.yml


# Ignore SimpleTest multi-site environment.
web/sites/simpletest


# Ignore files generated by PhpStorm
/.idea/
/.editorconfig
/.gitattributes
